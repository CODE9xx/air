# =============================================================================
# Code9 Analytics — пример .env (development)
# Скопируй в .env и заполни значения. НЕ коммить .env в git.
# =============================================================================

# --- Окружение ---
APP_ENV=development                 # development | staging | production
DEBUG=true
BASE_URL=http://localhost:8000

# --- База данных ---
POSTGRES_DSN=postgresql://code9:code9@postgres:5432/code9
POSTGRES_USER=code9
POSTGRES_PASSWORD=code9
POSTGRES_DB=code9
DATABASE_URL=postgresql+asyncpg://code9:code9@postgres:5432/code9

# --- Redis (cache + RQ) ---
REDIS_URL=redis://redis:6379/0

# --- Безопасность (Security) ---
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE-ME-DEV-ONLY
ADMIN_JWT_SECRET=CHANGE-ME-ADMIN-DEV-ONLY
# Сгенерируй: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE-ME-32-URL-SAFE-B64-BYTES=

# --- Mock-режим ---
MOCK_CRM_MODE=true                  # true => CRM-коннекторы используют фикстуры, никаких реальных HTTP
EMAIL_BACKEND=console               # console | smtp — в dev все письма выводятся в stdout
DEV_EMAIL_MODE=log                  # log | smtp (используется apps/api)

# --- SMTP (используется только при EMAIL_BACKEND=smtp) ---
# В dev можно оставить пустым и держать EMAIL_BACKEND=console.
SMTP_HOST=
SMTP_PORT=587
SMTP_MODE=starttls                  # starttls | ssl | none
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@code9.local
SMTP_TIMEOUT_SECONDS=10

# --- Bootstrap admin (создаётся миграцией/seed-скриптом при первом запуске) ---
ADMIN_BOOTSTRAP_EMAIL=admin@code9.local
ADMIN_BOOTSTRAP_PASSWORD=admin-demo-password

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ru
ALLOWED_ORIGINS=http://localhost:3000

# --- amoCRM / Kommo OAuth (placeholder, в MVP не используется) ---
# AMOCRM_AUTH_MODE: static_client | external_button (см. .env.production.template §9b).
AMOCRM_AUTH_MODE=static_client
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=http://localhost:8000/api/v1/crm/oauth/amocrm/callback
# external_button-only: publicный HTTPS-endpoint, на который amoCRM присылает
# client_id/client_secret (official amoCRM name — data-secrets_uri).
# Primary: AMOCRM_SECRETS_URI. Legacy alias AMOCRM_EXTERNAL_WEBHOOK_URL
# оставлен для backward compat — используется только если SECRETS_URI пуст.
AMOCRM_SECRETS_URI=
AMOCRM_EXTERNAL_WEBHOOK_URL=
AMOCRM_EXTERNAL_WAIT_SECONDS=5.0
# Публичная метаинформация кнопки (для <script class="amocrm_oauth"> data-*).
# Секретов не содержит; фронт берёт её через /oauth/button-config.
AMOCRM_BUTTON_NAME=
AMOCRM_BUTTON_DESCRIPTION=
AMOCRM_BUTTON_LOGO=https://aicode9.ru/code9-amocrm-marketplace.png
AMOCRM_BUTTON_SCOPES=
AMOCRM_BUTTON_TITLE=

# --- DaData / T-Bank billing ---
# Секреты не выводить в логи. Если T-Bank не заполнен, card-payment API
# вернёт controlled 501 и приложение продолжит работать.
DADATA_API_KEY=
DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/party
TBANK_EACQ_TERMINAL_KEY=
TBANK_EACQ_PASSWORD=
TBANK_EACQ_API_URL=https://securepay.tinkoff.ru/v2
TBANK_EACQ_SUCCESS_URL=
TBANK_EACQ_FAIL_URL=
TBANK_EACQ_TAXATION=usn_income
TBANK_EACQ_VAT=none

# --- YooKassa (legacy placeholder) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Stripe (placeholder) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- LLM провайдер (placeholder, V1) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# --- Логи ---
LOG_LEVEL=info                      # debug | info | warning | error
