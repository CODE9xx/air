# =============================================================================
# Code9 Analytics — пример .env (development)
# Скопируй в .env и заполни значения. НЕ коммить .env в git.
# =============================================================================

# --- Окружение ---
APP_ENV=development                 # development | staging | production
DEBUG=true
BASE_URL=http://localhost:8000

# --- База данных ---
POSTGRES_DSN=postgresql://code9:code9@postgres:5432/code9
POSTGRES_USER=code9
POSTGRES_PASSWORD=code9
POSTGRES_DB=code9
DATABASE_URL=postgresql+asyncpg://code9:code9@postgres:5432/code9

# --- Redis (cache + RQ) ---
REDIS_URL=redis://redis:6379/0

# --- Безопасность (Security) ---
# Сгенерируй: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE-ME-DEV-ONLY
ADMIN_JWT_SECRET=CHANGE-ME-ADMIN-DEV-ONLY
# Сгенерируй: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE-ME-32-URL-SAFE-B64-BYTES=

# --- Mock-режим ---
MOCK_CRM_MODE=true                  # true => CRM-коннекторы используют фикстуры, никаких реальных HTTP
EMAIL_BACKEND=console               # console | smtp — в dev все письма выводятся в stdout
DEV_EMAIL_MODE=log                  # log | smtp (используется apps/api)

# --- Bootstrap admin (создаётся миграцией/seed-скриптом при первом запуске) ---
ADMIN_BOOTSTRAP_EMAIL=admin@code9.local
ADMIN_BOOTSTRAP_PASSWORD=admin-demo-password

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ru
ALLOWED_ORIGINS=http://localhost:3000

# --- amoCRM / Kommo OAuth (placeholder, в MVP не используется) ---
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=http://localhost:8000/api/v1/crm/oauth/amocrm/callback

# --- YooKassa (placeholder) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Stripe (placeholder) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- LLM провайдер (placeholder, V1) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# --- Логи ---
LOG_LEVEL=info                      # debug | info | warning | error
