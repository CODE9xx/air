# =============================================================================
# Code9 Analytics — .env.production (SHABLON)
#
# 1. Скопируй: cp .env.production.template .env.production
# 2. Заполни ВСЕ значения CHANGE_ME_* реальными секретами.
# 3. chmod 600 .env.production
# 4. НИКОГДА не коммить .env.production в git (он в .gitignore).
#
# Генераторы секретов:
#   JWT/ADMIN_JWT:   python -c "import secrets; print(secrets.token_urlsafe(64))"
#   FERNET_KEY:      python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Postgres pass:   python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# --- Окружение ---------------------------------------------------------------
# APP_ENV=production триггерит fail-fast валидатор в Settings:
# контейнер НЕ стартует, если JWT_SECRET / ADMIN_JWT_SECRET / FERNET_KEY дефолтные.
APP_ENV=production
DEBUG=false
LOG_LEVEL=info

# --- Публичные URLы ---------------------------------------------------------
# Замени example.com на реальные домены перед первым запуском
PUBLIC_APP_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com
BASE_URL=https://api.example.com

# --- База данных -------------------------------------------------------------
# Выбери ОДИН из двух вариантов ниже и удали второй блок целиком.
#
# =============================================================================
# ВАРИАНТ A — Postgres в docker (docker-compose.prod.yml, generic VPS)
# =============================================================================
# POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB используются и контейнером postgres
# (initdb через docker-entrypoint), и pg_dump.sh, и restore.sh. Все три обязательны.
POSTGRES_USER=code9
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
POSTGRES_DB=code9
POSTGRES_DSN=postgresql://code9:CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/code9
DATABASE_URL=postgresql+asyncpg://code9:CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/code9

# =============================================================================
# ВАРИАНТ B — Timeweb managed Postgres (docker-compose.prod.timeweb.yml)
# =============================================================================
# Раскомментируй блок ниже и закомментируй блок выше, если используешь внешнюю БД.
# Все значения возьми из панели Timeweb → Кластеры баз данных → твой кластер.
#
# Хост:       приватный IP (192.168.0.X) — доступен только из VPS в той же приватной сети.
#             Публичный хост — только если VPS и БД в разных регионах (ssl обязателен).
# Порт:       5432 (стандарт)
# Пользователь: gen_user (Timeweb дефолт) или созданный тобой
# БД:         default_db (Timeweb дефолт) или созданная тобой
# SSL:        sslmode=require — Timeweb managed Postgres требует TLS
#
# ВАЖНО:
#   1. POSTGRES_USER / POSTGRES_DB нужны скриптам pg_dump_managed.sh / restore_managed.sh
#      и Makefile-таргетам — НЕ удалять.
#   2. POSTGRES_PASSWORD здесь используется ТОЛЬКО скриптами бэкапа/restore
#      (они читают .env.production и формируют PGPASSWORD). В compose контейнер
#      postgres отсутствует — initdb не нужен.
#   3. DATABASE_URL (asyncpg) — для FastAPI/SQLAlchemy.
#   4. POSTGRES_DSN (psycopg/psql-совместимый) — для sync-скриптов, alembic-scripts,
#      bash-утилит.
#
# POSTGRES_HOST=192.168.0.4
# POSTGRES_PORT=5432
# POSTGRES_USER=gen_user
# POSTGRES_PASSWORD=CHANGE_ME_TIMEWEB_DB_PASSWORD
# POSTGRES_DB=default_db
# POSTGRES_DSN=postgresql://gen_user:CHANGE_ME_TIMEWEB_DB_PASSWORD@192.168.0.4:5432/default_db?sslmode=require
# DATABASE_URL=postgresql+asyncpg://gen_user:CHANGE_ME_TIMEWEB_DB_PASSWORD@192.168.0.4:5432/default_db?ssl=require

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Security (ВСЕ обязательны, иначе контейнер упадёт при старте) ---------
JWT_SECRET=CHANGE_ME_64_BYTE_URL_SAFE_TOKEN
ADMIN_JWT_SECRET=CHANGE_ME_64_BYTE_URL_SAFE_TOKEN_DIFFERENT_FROM_ABOVE
FERNET_KEY=CHANGE_ME_VALID_44_CHAR_FERNET_KEY_ENDING_WITH_EQUALS=

# --- CORS (только prod-домены; обязательно без wildcard в prod) -------------
ALLOWED_ORIGINS=https://app.example.com
CORS_ORIGINS=https://app.example.com

# --- CRM mock / real ---------------------------------------------------------
# В Sprint 0 оставляем mock=true. Перевод на реальные CRM — Sprint 4, после
# closing gate A/B и подключения SMTP + rolling refresh.
MOCK_CRM_MODE=true

# --- Email (Gate B → Timeweb SMTP) ------------------------------------------
# Backend:
#   console — письма в stdout/логи (подходит только для dev/первого деплоя).
#   smtp    — реальная отправка (production). В prod validator настоит на
#             заполнении SMTP_HOST + SMTP_FROM при EMAIL_BACKEND=smtp.
#
# Timeweb SMTP (реквизиты — панель Timeweb → Почта → ящик noreply@aicode9.ru):
#   SMTP_HOST=smtp.timeweb.ru
#   SMTP_PORT=465        # ssl
#   SMTP_PORT=587        # starttls
#   SMTP_USER=noreply@aicode9.ru
#   SMTP_PASSWORD=<пароль ящика из панели>
#   SMTP_FROM=noreply@aicode9.ru
#   SMTP_MODE=starttls   # starttls | ssl | none
#
# DNS (однократно, чтобы письма не улетали в спам):
#   SPF:   v=spf1 include:_spf.timeweb.ru ~all
#   DKIM:  публичный ключ — панель Timeweb → Почта → DKIM
#   DMARC: v=DMARC1; p=quarantine; rua=mailto:postmaster@aicode9.ru
EMAIL_BACKEND=console
DEV_EMAIL_MODE=log
SMTP_HOST=
SMTP_PORT=587
SMTP_MODE=starttls
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TIMEOUT_SECONDS=10

# --- Admin bootstrap (одноразовый) -------------------------------------------
# СМЕНИТЬ пароль в UI после первого логина, НЕ оставлять admin-demo-password.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# --- Frontend (Next.js build-time + runtime) ---------------------------------
NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_DEFAULT_LOCALE=ru

# --- Платежи (Sprint 4, сейчас mock) -----------------------------------------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- LLM (Sprint 4+, пока не используется) -----------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# --- Real CRM OAuth (Gate B Phase 2A — см. docs/deploy/INSTALL_TIMEWEB.md §9b) ---
# AMOCRM_AUTH_MODE управляет тем, как мы получаем client_id / client_secret:
#
#   static_client   — единый набор client_id/client_secret в .env (классика OAuth 2.0,
#                     подходит для self-hosted интеграции amoCRM, когда приложение
#                     зарегистрировано один раз и все установки используют одну
#                     пару credentials). AMOCRM_CLIENT_ID / AMOCRM_CLIENT_SECRET
#                     обязательны.
#
#   external_button — amoCRM создаёт интеграцию в момент установки из маркетплейса
#                     и присылает per-install credentials на наш secrets URI
#                     (AMOCRM_SECRETS_URI; official amoCRM name — data-secrets_uri).
#                     Для этого режима AMOCRM_CLIENT_ID / AMOCRM_CLIENT_SECRET
#                     НЕ нужны — они приходят в POST
#                     /api/v1/integrations/amocrm/external/secrets (primary,
#                     или legacy alias .../credentials) и шифруются Fernet'ом
#                     перед записью в БД. AMOCRM_SECRETS_URI обязателен и
#                     ДОЛЖЕН совпадать посимвольно с тем, что зарегистрирован
#                     в панели amoCRM.
#
# Регистрация интеграции (static_client): amoCRM → Настройки → Интеграции → «+» → OAuth 2.0.
# Регистрация интеграции (external_button): amoCRM → Рабочий стол → «+» → маркетплейс,
#   в панели разработчика задать Secrets URI = AMOCRM_SECRETS_URI.
#
# redirect_uri в панели amoCRM ДОЛЖЕН совпадать с AMOCRM_REDIRECT_URI здесь
# посимвольно в обоих режимах — amoCRM отбросит exchange_code с кодом invalid_grant иначе.
# Реальный роут: apps/api/app/crm/oauth_router.py → /integrations/amocrm/oauth/callback
# Fallback (если AMOCRM_REDIRECT_URI пустой): ${BASE_URL}/api/v1/integrations/amocrm/oauth/callback
AMOCRM_AUTH_MODE=static_client
AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=https://api.example.com/api/v1/integrations/amocrm/oauth/callback

# external_button-only: URL, на который amoCRM пришлёт POST с client_id/secret.
# В панели amoCRM ↔ наш backend этот URL должен совпадать посимвольно.
# Primary роут: apps/api/app/crm/external_router.py → /integrations/amocrm/external/secrets
# Legacy alias (обратная совместимость): .../external/credentials (тот же handler).
AMOCRM_SECRETS_URI=
# Deprecated legacy alias. Используется только если AMOCRM_SECRETS_URI пуст —
# на новых деплоях заполняй AMOCRM_SECRETS_URI и оставляй эту переменную пустой.
AMOCRM_EXTERNAL_WEBHOOK_URL=
# Сколько секунд callback ждёт webhook с credentials (default: 5.0).
# Увеличивай только если amoCRM стабильно присылает webhook с задержкой >5s.
AMOCRM_EXTERNAL_WAIT_SECONDS=5.0

# Публичная метаинформация кнопки (идёт во фронтовый <script class="amocrm_oauth">
# data-* атрибутами). Секретов не содержит — фронт забирает через
# GET /api/v1/integrations/amocrm/oauth/button-config.
AMOCRM_BUTTON_NAME=
AMOCRM_BUTTON_DESCRIPTION=
AMOCRM_BUTTON_LOGO=
AMOCRM_BUTTON_SCOPES=
AMOCRM_BUTTON_TITLE=

# --- Backup ------------------------------------------------------------------
# Используется deploy/backup/pg_dump.sh и restore.sh
BACKUP_DIR=/var/backups/code9
RETAIN_DAYS=14
